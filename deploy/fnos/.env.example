# 飞牛 OS 部署用环境变量（复制为同目录 .env 后修改）
POSTGRES_PASSWORD=请改成强密码
JWT_SECRET=请用 openssl rand -hex 32 生成
JWT_REFRESH_SECRET=请再生成一个
# 浏览器访问地址，多个用逗号分隔（含手机/桌面若走网页调试）
CORS_ORIGIN=http://192.168.1.100:8080
# 对外映射的网页端口（与 compose 中 web 的 ports 左侧一致）
WEB_PORT=8080
API_PORT=3001
# Webhook 自动部署端口（可选，见 setup-webhook.sh）
DEPLOY_HOOK_PORT=9000

# 邮件 SMTP（注册/找回密码验证码；未配置时验证码写入 API 容器日志）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NovelReader <noreply@example.com>
